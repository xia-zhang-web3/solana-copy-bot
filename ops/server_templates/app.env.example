# CopyBot app server env template.
# Target path on server: /etc/solana-copy-bot/app.env

# Explicitly point runtime to server config.
SOLANA_COPY_BOT_CONFIG=/etc/solana-copy-bot/live.server.toml

# Set to true for execution runtime checks / rollout stages when needed.
# Keep false during pure shadow warm-up.
SOLANA_COPY_BOT_EXECUTION_ENABLED=false

# App-specific tracing filter. Avoid ambient RUST_LOG.
COPYBOT_APP_LOG_FILTER=info
