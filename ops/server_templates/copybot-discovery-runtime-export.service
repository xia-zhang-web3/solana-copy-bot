[Unit]
Description=Copybot Discovery Runtime Artifact Export
After=solana-copy-bot.service

[Service]
Type=oneshot
User=copybot
WorkingDirectory=/var/www/solana-copy-bot
EnvironmentFile=/etc/solana-copy-bot/app.env
ExecStart=/var/www/solana-copy-bot/target/release/discovery_runtime_export --config /etc/solana-copy-bot/live.server.toml --scheduled --json

