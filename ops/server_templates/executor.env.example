# CopyBot executor server env template (test-server bring-up).
# Target path on server: /etc/solana-copy-bot/executor.env

COPYBOT_EXECUTOR_BIND_ADDR=127.0.0.1:8090
COPYBOT_EXECUTOR_CONTRACT_VERSION=v1
COPYBOT_EXECUTOR_ROUTE_ALLOWLIST=jito,rpc
COPYBOT_EXECUTOR_SUBMIT_FASTLANE_ENABLED=false
COPYBOT_EXECUTOR_ALLOW_UNAUTHENTICATED=false
# COPYBOT_EXECUTOR_BACKEND_MODE=upstream
# Use `mock` for in-process non-live contour (no external upstream process needed).

# Signer contract
COPYBOT_EXECUTOR_SIGNER_SOURCE=file
COPYBOT_EXECUTOR_SIGNER_PUBKEY=11111111111111111111111111111111
COPYBOT_EXECUTOR_SIGNER_KEYPAIR_FILE=/etc/solana-copy-bot/secrets/executor-signer.devnet.json
# COPYBOT_EXECUTOR_SIGNER_KMS_KEY_ID=optional_kms_key

# Ingress auth (required when unauthenticated mode is false)
COPYBOT_EXECUTOR_BEARER_TOKEN_FILE=/etc/solana-copy-bot/secrets/executor_bearer.token

# Upstream topology for safe non-live execution contour (adapter -> executor -> local mock).
COPYBOT_EXECUTOR_UPSTREAM_SUBMIT_URL=http://127.0.0.1:18080/submit
COPYBOT_EXECUTOR_UPSTREAM_SIMULATE_URL=http://127.0.0.1:18080/simulate

# Optional fallback topology (must be distinct from primary endpoint identity)
# COPYBOT_EXECUTOR_UPSTREAM_SUBMIT_FALLBACK_URL=https://...
# COPYBOT_EXECUTOR_UPSTREAM_SIMULATE_FALLBACK_URL=https://...

# Optional send-rpc topology
# COPYBOT_EXECUTOR_SEND_RPC_URL=https://...
# COPYBOT_EXECUTOR_SEND_RPC_FALLBACK_URL=https://...

# Optional upstream auth
# COPYBOT_EXECUTOR_UPSTREAM_AUTH_TOKEN_FILE=/etc/solana-copy-bot/secrets/executor_upstream_auth.token
# COPYBOT_EXECUTOR_UPSTREAM_FALLBACK_AUTH_TOKEN_FILE=/etc/solana-copy-bot/secrets/executor_upstream_fallback_auth.token
# COPYBOT_EXECUTOR_SEND_RPC_AUTH_TOKEN_FILE=/etc/solana-copy-bot/secrets/executor_send_rpc_auth.token
# COPYBOT_EXECUTOR_SEND_RPC_FALLBACK_AUTH_TOKEN_FILE=/etc/solana-copy-bot/secrets/executor_send_rpc_fallback_auth.token

# Optional HMAC ingress auth chain
# COPYBOT_EXECUTOR_HMAC_KEY_ID=executor-hmac-k1
# COPYBOT_EXECUTOR_HMAC_SECRET_FILE=/etc/solana-copy-bot/secrets/executor_hmac_secret.token
# COPYBOT_EXECUTOR_HMAC_TTL_SEC=30
