# CopyBot adapter server env template (test-server bring-up).
# Target path on server: /etc/solana-copy-bot/adapter.env

COPYBOT_ADAPTER_BIND_ADDR=127.0.0.1:8080
COPYBOT_ADAPTER_CONTRACT_VERSION=v1
COPYBOT_ADAPTER_SIGNER_PUBKEY=REPLACE_WITH_TEST_SIGNER_PUBKEY
COPYBOT_ADAPTER_ROUTE_ALLOWLIST=paper,rpc
COPYBOT_ADAPTER_ALLOW_UNAUTHENTICATED=false

# Adapter ingress auth
COPYBOT_ADAPTER_BEARER_TOKEN_FILE=/etc/solana-copy-bot/secrets/adapter_bearer.token

# Executor upstream endpoints (required)
COPYBOT_ADAPTER_UPSTREAM_SUBMIT_URL=http://127.0.0.1:8090/submit
COPYBOT_ADAPTER_UPSTREAM_SIMULATE_URL=http://127.0.0.1:8090/simulate

# Optional fallback endpoints (must be distinct from primary endpoint identity)
# COPYBOT_ADAPTER_UPSTREAM_SUBMIT_FALLBACK_URL=http://127.0.0.1:8091/submit
# COPYBOT_ADAPTER_UPSTREAM_SIMULATE_FALLBACK_URL=http://127.0.0.1:8091/simulate

# Upstream auth to executor (must match executor bearer token when auth is required)
COPYBOT_ADAPTER_UPSTREAM_AUTH_TOKEN_FILE=/etc/solana-copy-bot/secrets/executor_bearer.token
# COPYBOT_ADAPTER_UPSTREAM_FALLBACK_AUTH_TOKEN_FILE=/etc/solana-copy-bot/secrets/executor_bearer.token

# Optional send-rpc topology
# COPYBOT_ADAPTER_SEND_RPC_URL=https://...
# COPYBOT_ADAPTER_SEND_RPC_FALLBACK_URL=https://...
# COPYBOT_ADAPTER_SEND_RPC_AUTH_TOKEN_FILE=/etc/solana-copy-bot/secrets/adapter_send_rpc_auth.token
# COPYBOT_ADAPTER_SEND_RPC_FALLBACK_AUTH_TOKEN_FILE=/etc/solana-copy-bot/secrets/adapter_send_rpc_fallback_auth.token

# Optional route-scoped overrides (examples)
# COPYBOT_ADAPTER_ROUTE_RPC_SUBMIT_URL=http://127.0.0.1:8090/submit
# COPYBOT_ADAPTER_ROUTE_RPC_SIMULATE_URL=http://127.0.0.1:8090/simulate
# COPYBOT_ADAPTER_ROUTE_RPC_AUTH_TOKEN_FILE=/etc/solana-copy-bot/secrets/executor_bearer.token
