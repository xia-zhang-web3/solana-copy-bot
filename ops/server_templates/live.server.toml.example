# Synced with staging server snapshot (52.28.0.218, 2026-03-03).
# This footprint is for shadow + non-live execution contour tests.

[system]
env = "prod-live"
log_level = "info"
log_json = true
heartbeat_seconds = 30
migrations_dir = "migrations"
pause_new_trades_on_outage = true

[sqlite]
path = "state/live_runtime.db"

[recent_raw_journal]
path = "state/discovery_recent_raw.db"
retention_safety_buffer_days = 2
writer_queue_capacity_batches = 64
replay_batch_size = 1024

[recent_raw_gap_fill]
source = "helius_rpc"
# Intentionally placeholder-only in repo. Populate a historical raw RPC source
# only in the server-local copy of this file or via an explicit CLI override.
helius_http_url = "https://YOUR_HISTORICAL_HELIUS_HOST/REPLACE_ON_SERVER/"
output_dir = "state/discovery_restore/gap_fill"
output_retention = 16
request_timeout_ms = 20000
signature_page_size = 1000
max_signature_pages_per_wallet = 64

[recent_raw_gap_fill_helius]
# Intentionally placeholder-only in repo. Populate a Helius historical RPC
# endpoint that supports getTransactionsForAddress only in the server-local copy
# of this file or via an explicit CLI override.
helius_http_url = "https://mainnet.helius-rpc.com/?api-key=REPLACE_ON_SERVER"
output_dir = "state/discovery_restore/gap_fill_helius"
output_retention = 16
request_timeout_ms = 20000
page_size = 100
max_pages_per_wallet = 64

[program_history_validation]
source = "quicknode_blocks_rpc"
# Validation-only surface. This probes whether QuickNode block-history RPC can
# support the next program-scoped raw recovery step via getSlot/getBlockTime/
# getBlocks/getBlock. It does not itself restore coverage or change readiness.
# Populate the QuickNode HTTP RPC endpoint only in the server-local copy of this
# file or via an explicit CLI override.
# QuickNode currently throttles this validation path at 125 req/s. Keep the
# local limiter below that ceiling so the tool does not self-inflict 429 storms.
# Phase A is the cheap default: it proves target-program presence only and can
# return `viable_enough_for_phase_b` without claiming final parseability/usefulness.
# Phase B is the expensive escalation: it uses the larger parse budget below.
# Phase B also has its own internal cost budget so the tool returns terminal
# JSON instead of hanging until an external timeout kills the process.
http_url = "https://YOUR_QUICKNODE_HOST.solana-mainnet.quiknode.pro/REPLACE_ON_SERVER/"
request_timeout_ms = 20000
max_requests_per_second = 100
retry_429_max_attempts = 4
retry_429_backoff_ms = 250
block_batch_size = 512
phase_a_max_slots_to_scan = 4096
phase_a_sampling_segments = 8
phase_a_max_blocks_per_window = 12
phase_b_max_blocks_to_fetch = 1024
phase_b_max_candidate_transactions_to_parse = 2048
phase_b_parseable_rows_target = 1
max_slots_to_scan = 20000
sampling_segments = 8
block_time_probe_slots = 128
raydium_program_ids = [
  "675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8",
  "CPMMoo8L3F4NbTegBCKVN6DKuQh8fYfY4yR4j3uP9s5",
]
pumpswap_program_ids = ["pAMMBay6oceH9fJKBRHGP5D4bD4sWpmSwMn52FMfXEA"]

[program_history_gap_fill]
source = "quicknode_blocks_rpc"
# Production program-scoped gap-fill path. This uses the same proven QuickNode
# block-history contract as validation, but it writes a standalone recent-raw
# sqlite output for restore replay. It never writes into the active runtime DB.
# Keep this source on the same QuickNode HTTP RPC family; do not silently swap
# to wallet-history or another provider here.
http_url = "https://YOUR_QUICKNODE_HOST.solana-mainnet.quiknode.pro/REPLACE_ON_SERVER/"
request_timeout_ms = 20000
# Keep the local limiter below QuickNode's observed 125 req/s ceiling. This
# path is heavier than validation, so the repo default stays conservative.
max_requests_per_second = 60
retry_429_max_attempts = 6
retry_429_backoff_ms = 500
# `getBlocks` supports up to 1005 slots per request. Use the max to reduce
# list-call pressure on live-sized bounded windows.
block_batch_size = 1005
# Parallelize `getBlock` under the same global request pacer to hide single-call
# latency without exceeding the configured QuickNode req/s contract.
block_fetch_concurrency = 12
block_time_probe_slots = 128
# This budget is intentionally sized above the current live missing window so
# the default operator path can attempt a full bounded scan instead of staged
# sampling. If the incident window grows beyond this, the tool returns a bounded
# `not_proven_due_to_scan_budget` outcome and withholds replayable rows.
max_slots_to_scan = 1200000
sampling_segments = 8
# Each invocation scans at most this many slot batches before returning its own
# terminal JSON. Re-run the same command to continue from the persisted
# in_progress state; replayable output is published only after a completed run.
max_slot_batches_per_attempt = 256
# These are explicit internal cost ceilings for the expensive parse/write pass.
# If they exhaust, the tool returns a terminal bounded not-proven outcome instead
# of hanging until an external timeout kills the process.
max_blocks_to_fetch = 120000
max_candidate_transactions_to_parse = 240000
output_dir = "state/discovery_restore/gap_fill_program_history"
output_retention = 16
raydium_program_ids = [
  "675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8",
  "CPMMoo8L3F4NbTegBCKVN6DKuQh8fYfY4yR4j3uP9s5",
]
pumpswap_program_ids = ["pAMMBay6oceH9fJKBRHGP5D4bD4sWpmSwMn52FMfXEA"]

[runtime_restore_ops]
artifact_dir = "state/discovery_restore/artifacts"
artifact_retention = 288
artifact_cadence_minutes = 10
journal_snapshot_dir = "state/discovery_restore/recent_raw"
journal_snapshot_retention = 144
journal_snapshot_cadence_minutes = 10
drill_workspace_dir = "state/discovery_restore/drills"

[history_retention]
enabled = true
sweep_seconds = 3600
protected_history_days = 30
risk_events_days = 30
copy_signals_days = 30
orders_days = 30
fills_days = 30
shadow_closed_trades_days = 90

[ingestion]
source = "yellowstone_grpc"
# Intentionally placeholder-only in repo. Populate real RPC credentials only in
# the server-local copy of this file or via env overrides.
helius_ws_url = "wss://YOUR_QUICKNODE_HOST.solana-mainnet.quiknode.pro/REPLACE_ON_SERVER/"
helius_http_url = "https://YOUR_QUICKNODE_HOST.solana-mainnet.quiknode.pro/REPLACE_ON_SERVER/"
helius_http_urls = []
yellowstone_grpc_url = "https://YOUR_QUICKNODE_HOST.solana-mainnet.quiknode.pro:10000"
yellowstone_x_token = "REPLACE_ON_SERVER"
yellowstone_connect_timeout_ms = 5000
yellowstone_subscribe_timeout_ms = 15000
yellowstone_stream_buffer_capacity = 2048
yellowstone_reconnect_initial_ms = 500
yellowstone_reconnect_max_ms = 8000
yellowstone_program_ids = []
fetch_concurrency = 4
ws_queue_capacity = 512
output_queue_capacity = 2048
prefetch_stale_drop_ms = 30000
seen_signatures_ttl_ms = 600000
queue_overflow_policy = "drop_oldest"
reorder_hold_ms = 1200
reorder_max_buffer = 1024
telemetry_report_seconds = 30
subscribe_program_ids = []
raydium_program_ids = [
  "675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8",
  "CPMMoo8L3F4NbTegBCKVN6DKuQh8fYfY4yR4j3uP9s5",
]
pumpswap_program_ids = ["pAMMBay6oceH9fJKBRHGP5D4bD4sWpmSwMn52FMfXEA"]
reconnect_initial_ms = 500
reconnect_max_ms = 8000
tx_fetch_retries = 1
tx_fetch_retry_delay_ms = 500
tx_fetch_retry_max_ms = 2000
tx_fetch_retry_jitter_ms = 150
tx_request_timeout_ms = 5000
global_rpc_rps_limit = 45
per_endpoint_rpc_rps_limit = 16
seen_signatures_limit = 5000
mock_interval_ms = 2000

[discovery]
scoring_window_days = 5
decay_window_days = 5
follow_top_n = 15
min_leader_notional_sol = 0.5
helius_http_url = ""
fetch_refresh_seconds = 60
refresh_seconds = 600
min_trades = 10
min_active_days = 3
min_score = 0.4
max_tx_per_minute = 50
min_buy_count = 10
min_tradable_ratio = 0.25
max_rug_ratio = 1.0
rug_lookahead_seconds = 900
metric_snapshot_interval_seconds = 1800
max_bootstrap_snapshot_age_seconds = 43200
thin_market_min_volume_sol = 0.0
thin_market_min_unique_traders = 0
max_window_swaps_in_memory = 100000
max_fetch_swaps_per_cycle = 20000
max_fetch_pages_per_cycle = 5
fetch_time_budget_ms = 15000
observed_swaps_retention_days = 7
scoring_aggregates_write_enabled = false
scoring_aggregates_enabled = false

[shadow]
enabled = true
helius_http_url = ""
causal_holdback_enabled = true
causal_holdback_ms = 2500
refresh_seconds = 60
copy_notional_sol = 0.20
min_leader_notional_sol = 0.75
max_signal_lag_seconds = 30
quality_gates_enabled = true
min_token_age_seconds = 30
min_holders = 5
min_liquidity_sol = 1.0
min_volume_5m_sol = 0.5
min_unique_traders_5m = 1

[execution]
# Keep disabled by default until all rollout gates in ROAD_TO_PRODUCTION.md are closed.
enabled = false
mode = "adapter_submit_confirm"
poll_interval_ms = 750
batch_size = 32
default_route = "jito"
rpc_http_url = "https://api.mainnet-beta.solana.com"
rpc_fallback_http_url = ""
rpc_devnet_http_url = "https://api.devnet.solana.com"
submit_adapter_http_url = "http://127.0.0.1:8080/submit"
submit_adapter_fallback_http_url = ""
submit_adapter_devnet_http_url = "http://127.0.0.1:18080/submit"
submit_adapter_devnet_fallback_http_url = ""
submit_adapter_auth_token = ""
submit_adapter_auth_token_file = "/etc/solana-copy-bot/secrets/adapter_bearer.token"
submit_adapter_hmac_key_id = ""
submit_adapter_hmac_secret = ""
submit_adapter_hmac_secret_file = ""
submit_adapter_hmac_ttl_sec = 30
submit_adapter_contract_version = "v1"
submit_adapter_require_policy_echo = true
submit_fastlane_enabled = false
submit_allowed_routes = ["jito", "rpc"]
submit_route_order = ["jito", "rpc"]
submit_route_max_slippage_bps = { jito = 50.0, rpc = 50.0 }
submit_route_tip_lamports = { jito = 10000, rpc = 0 }
submit_route_compute_unit_limit = { jito = 300000, rpc = 300000 }
submit_route_compute_unit_price_micro_lamports = { jito = 1500, rpc = 1000 }
submit_dynamic_cu_price_enabled = false
submit_dynamic_cu_price_percentile = 75
submit_dynamic_cu_price_api_primary_url = ""
submit_dynamic_cu_price_api_fallback_url = ""
submit_dynamic_cu_price_api_auth_token = ""
submit_dynamic_cu_price_api_auth_token_file = ""
submit_dynamic_tip_lamports_enabled = false
submit_dynamic_tip_lamports_multiplier_bps = 10000
submit_timeout_ms = 3000
execution_signer_pubkey = "11111111111111111111111111111111"
pretrade_min_sol_reserve = 0.05
pretrade_max_fee_overhead_bps = 1000
pretrade_require_token_account = false
pretrade_max_priority_fee_lamports = 0
slippage_bps = 50.0
max_confirm_seconds = 15
max_submit_attempts = 3
simulate_before_submit = true

[tiny_live_policy]
# This is an explicit pre-activation envelope for later tiny-live discussion.
# It does not enable trading by itself. The audit command compares the current
# execution/risk/shadow config against this envelope and reports whether the
# current config is bounded enough yet.
enabled = true
max_trade_notional_sol = 0.05
max_batch_size = 1
max_concurrent_positions = 1
max_daily_loss_limit_pct = 1.0
allowed_routes = ["jito"]
require_policy_echo = true
max_pretrade_fee_overhead_bps = 1000
max_pretrade_priority_fee_lamports = 2000
max_route_slippage_bps = { jito = 50.0 }
max_route_tip_lamports = { jito = 10000 }
max_route_compute_unit_price_micro_lamports = { jito = 1500 }

[tiny_live_guardrails]
# This is an explicit post-activation rollback/monitoring envelope for later
# tiny-live discussion. It does not enable trading by itself. The audit command
# checks whether future stop conditions are bounded and operator-readable.
enabled = true
evaluation_window_seconds = 900
max_execution_error_rate_pct = 5.0
max_adapter_contract_failure_rate_pct = 1.0
max_policy_echo_mismatch_rate_pct = 1.0
max_fee_or_slippage_breach_rate_pct = 5.0
max_connectivity_degraded_window_seconds = 120
max_daily_realized_loss_sol = 0.05
max_consecutive_hard_failures = 3

[risk]
# Tiny-live defaults from Stage E (ROAD_TO_PRODUCTION.md).
max_position_sol = 0.10
max_total_exposure_sol = 0.30
max_exposure_per_token_sol = 0.10
max_concurrent_positions = 3
execution_buy_cooldown_seconds = 60
daily_loss_limit_pct = 1.0
max_drawdown_pct = 5.0
max_hold_hours = 1
shadow_stale_close_terminal_zero_price_hours = 2
shadow_stale_close_recovery_zero_price_enabled = false
max_copy_delay_sec = 4
shadow_killswitch_enabled = true
shadow_soft_exposure_cap_sol = 10.0
shadow_soft_exposure_resume_below_sol = 9.5
shadow_soft_pause_minutes = 15
shadow_hard_exposure_cap_sol = 12.0
shadow_drawdown_1h_stop_sol = -0.7
shadow_drawdown_1h_pause_minutes = 30
shadow_drawdown_6h_stop_sol = -2.5
shadow_drawdown_6h_pause_minutes = 240
shadow_drawdown_24h_stop_sol = -5.0
shadow_rug_loss_return_threshold = -0.70
shadow_rug_loss_window_minutes = 120
shadow_rug_loss_count_threshold = 3
shadow_rug_loss_rate_sample_size = 200
shadow_rug_loss_rate_threshold = 0.04
shadow_infra_window_minutes = 20
shadow_infra_lag_p95_threshold_ms = 10000
shadow_infra_lag_breach_minutes = 10
shadow_infra_replaced_ratio_threshold = 0.85
shadow_infra_rpc429_delta_threshold = 5
shadow_infra_rpc5xx_delta_threshold = 20
shadow_universe_min_active_follow_wallets = 15
shadow_universe_min_eligible_wallets = 80
shadow_universe_breach_cycles = 3
